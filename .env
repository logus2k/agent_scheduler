# Agent Scheduler — configuration (copy to .env; all values have safe defaults in config.py)

# --- Valkey connection (shared valkey-bus) ---
# Inside the compose network the host is the service name; from the host it is 127.0.0.1.
VALKEY_HOST=valkey-bus
VALKEY_PORT=6379

# --- Stream / discovery conventions (MUST match agent_bus) ---
STREAM_PREFIX=stream:
ACTIVE_STREAMS_KEY=streams:active

# --- RedisJobStore keys (namespaced; do not collide with agent_bus keys) ---
JOBS_KEY=agent_scheduler.jobs
RUN_TIMES_KEY=agent_scheduler.run_times

# --- Emission identity ---
SENDER_ID=agent_scheduler
DEFAULT_EVENT_TYPE=schedule.fired

# --- Publisher connection retry (startup resilience across compose projects) ---
CONNECT_RETRIES=30
CONNECT_RETRY_DELAY_S=2

# --- Resource retention (bound the keys/streams the emitter creates) ---
SID_TTL_S=3600
STREAM_MAXLEN=10000
STREAM_DELETE_ON_JOB_DELETE=false

# --- Admin API ---
API_HOST=0.0.0.0
API_PORT=6816

# --- Logging ---
LOG_LEVEL=INFO
